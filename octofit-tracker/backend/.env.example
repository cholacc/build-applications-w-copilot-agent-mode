# Example environment variables for Octofit Tracker backend
# Copy this file to .env and edit as needed for local development

# MongoDB connection string (used by the backend and seed scripts)
MONGO_URI=mongodb://127.0.0.1:27017/octofit_db

# Optional DB name (defaults to octofit_db when not set)
DB_NAME=octofit_db

# Codespaces provides this automatically; used to construct the Codespaces URL
CODESPACE_NAME=

# Node environment
NODE_ENV=development

# The backend currently listens on port 8000 by default.
# To change it, modify src/index.ts to read from PORT environment variable.
PORT=8000
